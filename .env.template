# Ptown monitoring credentials.
# Copy this file to `.env` and fill in the values. The `.env` file is read by
# the status scripts; it should never be committed to git or shared.
#
# File permissions are locked to your user only when you first create .env
# (the setup step in README.md runs `chmod 600`).

# --- Nuheat (heated floors) ---
# Login you use at https://www.mynuheat.com
NUHEAT_EMAIL=
NUHEAT_PASSWORD=

# --- Jacuzzi SmartTub ---
# Login you use in the SmartTub app
SMARTTUB_EMAIL=
SMARTTUB_PASSWORD=

# --- Google Nest (Smart Device Management API) ---
# These come from the one-time Nest setup walkthrough.
# Leave blank until we do that step.
NEST_PROJECT_ID=
NEST_CLIENT_ID=
NEST_CLIENT_SECRET=
NEST_REFRESH_TOKEN=

# --- SmartThings (Overhead Door garage, via OHD Anywhere → SmartThings link) ---
# Genie cut off direct Aladdin/OHD API access in Jan 2024, so we route through
# SmartThings (free Samsung account). Auth is an OAuth-In SmartApp (PATs were
# capped to 24h by Samsung's 2024-12-30 policy change — see
# smartthings_oauth.py). The refresh token ROTATES on every use; the value
# here is only the bootstrap. If both cached + bootstrap tokens die, run:
#     ./ptown smartthings_bootstrap        # or: python3 smartthings_bootstrap.py
# and follow the prompts (grants r:devices:* AND x:devices:* — the x scope is
# what lets the "close garage" button send commands).
# SMARTTHINGS_DEVICE_ID is optional — garage.py auto-discovers the door-capable
# device on first run and prints the ID to paste back here.
SMARTTHINGS_CLIENT_ID=
SMARTTHINGS_CLIENT_SECRET=
SMARTTHINGS_REFRESH_TOKEN=
SMARTTHINGS_REDIRECT_URI=
SMARTTHINGS_DEVICE_ID=

# --- Yale lock (via SmartThings) ---
# Yale's direct cloud API (and the yalexs library) requires OAuth credentials
# that Yale only issues to partners. SmartThings re-added Yale integration in
# 2026, so we route through SmartThings just like the garage door. Same PAT.
# SMARTTHINGS_LOCK_DEVICE_ID is optional — lock.py auto-discovers the
# lock-capable device on the account. Pin it after first run to skip the
# discovery call.
SMARTTHINGS_LOCK_DEVICE_ID=

# --- Somfy TaHoma (awnings) ---
# Login you use in the "TaHoma by Somfy" app. The awnings are RTS motors —
# one-way radio, no position feedback — so tahoma.py is CONTROL-ONLY and is
# not part of the hourly monitoring run. Used by the awnings_close /
# awnings_open control buttons. Requires Python 3.12+ locally (pyoverkiz).
TAHOMA_EMAIL=
TAHOMA_PASSWORD=

# --- One-tap toggle (optional) ---
# Cloudflare Worker URL + shared HMAC secret. When both are set, the email
# toggle button becomes a true one-tap action (Worker performs the GitHub
# commit on Daniel's behalf). When unset, the button falls back to the
# GitHub web-UI flow (still works, just two taps). See cloudflare-worker/
# SETUP.md for deploy instructions.
WORKER_URL=
TOGGLE_SECRET=
